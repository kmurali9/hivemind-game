rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Game picks: one per user per game day, no overwrites
    match /games/{gameId}/picks/{userId} {
      allow create: if request.auth != null
                    && userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['name', 'selections', 'lockedRow', 'timestamp'])
                    && request.resource.data.selections is list
                    && request.resource.data.selections.size() == 5;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Daily events: anyone authenticated can increment counters
    match /daily_events/{dateStr} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /visitors/{visitorId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
