rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Game data
    match /games/{gameId} {
      allow read: if request.auth != null;

      // Picks: one per user per game. Update allowed on own doc only (for admin testing).
      match /picks/{pickId} {
        allow create: if request.auth != null
                      && pickId == request.auth.uid
                      && request.resource.data.keys().hasAll(['name', 'selections', 'lockedRow', 'timestamp'])
                      && request.resource.data.selections is list
                      && request.resource.data.selections.size() == 5;
        allow update: if request.auth != null
                      && pickId == request.auth.uid;
        allow read: if request.auth != null;
        allow delete: if false;
      }

      // Device lock (legacy — kept for backward compatibility)
      match /devices/{deviceId} {
        allow create, update: if request.auth != null;
        allow read: if request.auth != null;
        allow delete: if false;
      }
    }

    // Player identity (email hash based)
    match /players/{emailHash} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null;
      allow delete: if false;

      // Per-game play record — create-only (the primary play restriction)
      match /games/{gameId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // Daily events: anyone authenticated can increment counters
    match /daily_events/{dateStr} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /visitors/{visitorId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
